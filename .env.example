# 应用配置
APP_NAME=AI新媒体专家系统
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=1

# 数据库配置
DATABASE_URL=sqlite:///./ai_media_expert.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_media_expert

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=1073741824  # 1GB
ALLOWED_VIDEO_EXTENSIONS=.mp4,.avi,.mov,.mkv,.flv,.wmv,.webm

# 视频下载配置
DOWNLOAD_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=5
DOWNLOAD_TIMEOUT=3600  # 1小时

# AI模型配置
MODEL_CACHE_DIR=./models
DEVICE=cpu  # cpu 或 cuda
BATCH_SIZE=1

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# 监控配置
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# 外部服务配置
# OpenAI API (可选)
# OPENAI_API_KEY=your-openai-api-key

# 安全配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒